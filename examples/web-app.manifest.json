{
  "project": {
    "name": "my-saas",
    "description": "SaaS multi-tenant avec dashboard analytics",
    "type": "web-app",
    "language": "fr"
  },
  "stack": {
    "languages": ["typescript", "python"],
    "frameworks": ["nextjs", "fastapi", "celery"],
    "databases": ["postgresql", "redis"],
    "runtime": "node",
    "testing": ["jest", "vitest", "pytest"],
    "linting": ["eslint", "ruff"],
    "package_managers": ["pnpm"],
    "monorepo_tools": [],
    "data_tools": [],
    "serverless": [],
    "desktop_frameworks": []
  },
  "workflow": {
    "git_strategy": "feature-branch",
    "ci_cd": "github-actions",
    "deploy_target": "vercel",
    "auto_deploy": true,
    "commit_language": "en",
    "deploy_command": "vercel --prod",
    "environments": ["staging", "production"],
    "health_check_url": "https://my-saas.vercel.app/api/health",
    "smoke_tests": ["curl $DEPLOY_URL/api/health"],
    "github_releases": true
  },
  "mcp_servers": ["github", "postgres", "brave-search"],
  "guards": {
    "lint": true,
    "type_check": true,
    "test_on_edit": false,
    "migration_check": false,
    "i18n_check": true,
    "secret_scan": true
  },
  "agents": [
    "architect", "reviewer", "tester", "deployer", "explorer",
    "security-auditor", "debug-detective", "doc-writer",
    "performance-analyst", "release-manager", "devops-engineer", "template-improver"
  ],
  "workflows": [
    "feature", "bugfix", "hotfix", "release", "security-audit",
    "dependency-update", "refactor", "onboard", "self-improve"
  ],
  "automation": {
    "self_improve_every_n_sessions": 10,
    "learning_file": "learning.md"
  },
  "security": {
    "secret_scan": true,
    "dependency_audit": true,
    "owasp_check": true
  }
}
